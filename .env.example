# ─────────────────────────────────────────────────────────────────
# WildSaura Identity Service — Environment Variables
# ─────────────────────────────────────────────────────────────────
# 1. Copy this file to .env.local for local development
# 2. Add these variables in Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── Firebase Config (from Firebase Console → Project Settings → Your Apps) ──
NEXT_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# ── Optional: Firebase Measurement ID (Analytics) ──
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── App URL (set to your Vercel domain in production) ──
# NEXT_PUBLIC_APP_URL=https://identity.wildsaura.com
